APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Local : true acceptable. Production : obligatoirement false (force aussi cote config si APP_ENV=production).
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — local : SQLite (pas de service MySQL ni de hostname « mysql » Docker)
# 1) Depuis le dossier backend : touch database/database.sqlite
# 2) php artisan migrate
# 3) php artisan db:seed
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Docker / production MySQL : remplacer par exemple :
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
CACHE_PREFIX=

# Queue
QUEUE_CONNECTION=database

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Plafond global /api (requetes par minute, par utilisateur Sanctum ou par IP). SEC-05. Defaut 240.
API_RATE_LIMIT_PER_MINUTE=240

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173
SANCTUM_TOKEN_PREFIX=
# Durée de vie des tokens Bearer API (minutes). 43200 = 30 jours (recommandé V1 passager). 1440 = 24 h.
SANCTUM_EXPIRATION_MINUTES=43200

# Compte revue App Store / Play Console (OTP sans SMS — voir OtpController).
# E.164 ou numéro local Bénin ; normalisé comme les vrais numéros. Vide = bypass désactivé.
REVIEW_LOGIN_PHONE=+229000000
REVIEW_LOGIN_OTP=123456
REVIEW_LOGIN_OTP_KEY=google-test-key

# KYA SMS Service
KYASMS_API_KEY=
KYASMS_BASE_URL=https://route.kyasms.com/api/v3
KYASMS_APP_ID=
KYASMS_FROM=


# OTP Configuration
OTP_BYPASS=false


# FCM / Firebase Admin (HTTP v1) — ne jamais commiter le JSON ; régénérer la clé dans Google Cloud si exposée.
# Projet mobile actuel (app passager) : kekenon (voir kekenon-app/google-services.json).
#
# Option A (recommandé en local) : télécharger la clé JSON puis :
#   cp ~/Downloads/kekenon-xxxxx.json backend/storage/app/firebase-service-account.json
#   (fichier déjà listé dans backend/.gitignore)
# Option B : chemin absolu ou secret Docker, ex. FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase.json
# Option C : une seule ligne dans .env — base64 sans retours : openssl base64 -A -in firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=storage/app/firebase-service-account.json

# GeniusPay (rechargement wallet) — clés tableau de bord : Paramètres → API
# Authentification marchand : https://pay.genius.ci/docs/api (X-API-Key + X-API-Secret)
GENIUSPAY_PUBLIC_KEY=pk_sandbox_
GENIUSPAY_SECRET_KEY=sk_sandbox_
# Ancienne variable (non utilisée comme Bearer) : si une seule clé pk_ ou sk_ y est encore, elle est prise en secours.
GENIUSPAY_WEBHOOK_SECRET=
GENIUSPAY_SANDBOX=true

# Gemini API — voix (POST /api/voice/search) + secours géocodage texte (voir GeocodingController quand Mapbox/Nominatim vides).
# Clé : https://aistudio.google.com/apikey — ne jamais commiter le fichier .env réel ; régénérer la clé si exposée.
# Liste des identifiants de modèles : https://ai.google.dev/gemini-api/docs/models/gemini (ex. gemini-2.0-flash, gemini-1.5-pro, gemini-2.5-pro-preview-03-25).
# Après modification : php artisan config:clear
GEMINI_API_KEY=
# Audio + extraction lieu (JSON structuré).
GEMINI_VOICE_MODEL=gemini-2.0-flash
# Texte uniquement : variantes de requête quand la recherche hybride ne renvoie aucun résultat (défaut = GEMINI_VOICE_MODEL si vide).
GEMINI_GEO_MODEL=

# Mapbox (pour cartes)
MAPBOX_TOKEN=

# Mail Services (optionnel)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (optionnel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Redis (optionnel)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Search radius for ride dispatch (in KM)
SEARCH_RADIUS_KM=10

# Versions mobiles (FEAT-11) — semver X.Y.Z
MOBILE_PASSENGER_MIN_VERSION=1.0.0
MOBILE_PASSENGER_LATEST_VERSION=1.1.0
MOBILE_PASSENGER_ANDROID_PACKAGE=com.kekenon.passenger
MOBILE_PASSENGER_ANDROID_URL=
MOBILE_PASSENGER_IOS_URL=

MOBILE_DRIVER_MIN_VERSION=1.0.0
MOBILE_DRIVER_LATEST_VERSION=1.1.0
MOBILE_DRIVER_ANDROID_PACKAGE=com.kekenon.driver
MOBILE_DRIVER_ANDROID_URL=
MOBILE_DRIVER_IOS_URL=

# Pusher/Soketi Configuration (temps réel)
BROADCAST_DRIVER=pusher
PUSHER_APP_ID=app-id
PUSHER_APP_KEY=app-key
PUSHER_APP_SECRET=app-secret
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_USE_TLS=false

# Seeder Passwords (Ne jamais commit les vraies valeurs!)
# Ces variables sont requises pour exécuter AdminAndDeveloperSeeder
ADMIN_SEED_PASSWORD=
DEV_SEED_PASSWORD=
